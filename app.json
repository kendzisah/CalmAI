{
  "expo": {
    "name": "CalmAI",
    "slug": "CalmAI",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcon-1024.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "calmai",
    "splash": {
      "image": "./assets/calmai-splash-art.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flocktechnologies.calmai",
      "icon": "./assets/AppIcon-1024.png",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flocktechnologies.calmai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAFA"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/notification-icon.png",
          "color": "#7C5CBF"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5360bdd-f441-4eda-9ce8-04afc9b3acba"
      }
    }
  }
}
