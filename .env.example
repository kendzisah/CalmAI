EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat public SDK key (per-platform; iOS uses the appl_... key, Android the goog_... key).
# Replace the previously hardcoded test key (test_QkdrENKZChNNxBKircPTViSAijI) with the real one.
EXPO_PUBLIC_REVENUECAT_KEY=appl_your_revenuecat_key_here

# AppsFlyer — required for TikTok and Meta ad attribution.
# DEV_KEY is found in AppsFlyer dashboard → App Settings.
# APP_ID is the numeric App Store ID (e.g. 1234567890), required for iOS attribution.
EXPO_PUBLIC_APPSFLYER_DEV_KEY=your-appsflyer-dev-key
EXPO_PUBLIC_APPSFLYER_APP_ID=000000000

# PostHog — product analytics: onboarding funnel, feature usage, conversion loss.
# Project API key (phc_...) from PostHog dashboard → Project Settings → API Keys.
# HOST defaults to us.i.posthog.com; change to eu.i.posthog.com for EU region.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_project_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
